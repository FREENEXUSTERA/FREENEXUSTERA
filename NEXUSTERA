<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>ⵜⴻⵔⵔⴰ ⵏⴻⵅⵓⵙ · Terra Nexus</title>
<link href="https://fonts.googleapis.com/css2?family=Cinzel+Decorative:wght@400;700;900&family=Rajdhani:wght@300;400;600;700&family=Space+Mono:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet"/>
<style>
  :root {
    --sand: #e8d5a3;
    --ochre: #c8a84b;
    --terracotta: #b5541c;
    --deep: #1a0f05;
    --ink: #0d1a0a;
    --moss: #2d4a1e;
    --sky: #1a3a5c;
    --azure: #2a6496;
    --danger: #8b1a1a;
    --ember: #d4441a;
    --glow: #f0c060;
    --tifinagh: 'Noto Sans Tifinagh', 'Cinzel Decorative', serif;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--deep);
    color: var(--sand);
    font-family: 'Rajdhani', sans-serif;
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* ─── TIFINAGH BACKGROUND PATTERN ─── */
  .tifinagh-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }
  .tifinagh-bg svg {
    width: 100%;
    height: 100%;
    opacity: 0.04;
  }

  /* ─── MAIN LAYOUT ─── */
  #app {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-rows: auto 1fr auto;
    min-height: 100vh;
  }

  /* ─── HEADER ─── */
  header {
    border-bottom: 2px solid var(--ochre);
    padding: 0 2rem;
    background: linear-gradient(180deg, rgba(26,15,5,0.98) 0%, rgba(26,15,5,0.85) 100%);
    position: sticky;
    top: 0;
    z-index: 100;
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    max-width: 1600px;
    margin: 0 auto;
    height: 70px;
  }
  .logo-area {
    display: flex;
    align-items: center;
    gap: 1rem;
  }
  .logo-tifinagh {
    font-size: 2.2rem;
    color: var(--ochre);
    letter-spacing: 0.1em;
    text-shadow: 0 0 20px rgba(200,168,75,0.5);
    font-family: 'Cinzel Decorative', serif;
  }
  .logo-sub {
    font-size: 0.65rem;
    color: var(--ochre);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    opacity: 0.7;
    line-height: 1.4;
  }
  .logo-divider {
    width: 1px;
    height: 40px;
    background: linear-gradient(to bottom, transparent, var(--ochre), transparent);
  }

  /* live clock */
  .live-clock {
    text-align: right;
  }
  .clock-time {
    font-family: 'Space Mono', monospace;
    font-size: 1.8rem;
    color: var(--glow);
    letter-spacing: 0.05em;
  }
  .clock-date {
    font-size: 0.7rem;
    color: var(--ochre);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  /* nav tabs */
  nav {
    display: flex;
    gap: 0;
  }
  nav button {
    background: none;
    border: none;
    border-bottom: 3px solid transparent;
    color: var(--sand);
    font-family: 'Rajdhani', sans-serif;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    padding: 0 1.2rem;
    height: 70px;
    cursor: pointer;
    transition: all 0.3s;
    opacity: 0.6;
  }
  nav button:hover { opacity: 1; color: var(--ochre); }
  nav button.active {
    border-bottom-color: var(--ochre);
    color: var(--ochre);
    opacity: 1;
  }

  /* ─── LIVE TICKER ─── */
  .ticker {
    background: var(--moss);
    border-bottom: 1px solid rgba(200,168,75,0.3);
    overflow: hidden;
    height: 32px;
    display: flex;
    align-items: center;
  }
  .ticker-label {
    background: var(--ochre);
    color: var(--deep);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    padding: 0 1rem;
    height: 100%;
    display: flex;
    align-items: center;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .ticker-track {
    display: flex;
    animation: ticker-scroll 35s linear infinite;
    white-space: nowrap;
  }
  .ticker-item {
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    padding: 0 2.5rem;
    color: var(--sand);
    opacity: 0.85;
  }
  .ticker-item span { color: var(--glow); font-weight: 700; }
  @keyframes ticker-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ─── MAIN CONTENT ─── */
  main {
    max-width: 1600px;
    margin: 0 auto;
    padding: 2rem;
    width: 100%;
  }

  /* ─── PANELS (tabs) ─── */
  .panel { display: none; animation: fadeIn 0.4s ease; }
  .panel.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  /* ─── SECTION TITLE ─── */
  .section-head {
    display: flex;
    align-items: flex-end;
    gap: 1.5rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid rgba(200,168,75,0.2);
    padding-bottom: 1rem;
  }
  .section-tifinagh {
    font-size: 3rem;
    color: var(--ochre);
    opacity: 0.5;
    line-height: 1;
    font-family: 'Cinzel Decorative', serif;
  }
  .section-title {
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--sand);
  }
  .section-sub {
    font-size: 0.75rem;
    color: var(--ochre);
    letter-spacing: 0.3em;
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }

  /* ─── OBSERVATOIRE (tab 1) ─── */
  .obs-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .stat-card {
    border: 1px solid rgba(200,168,75,0.25);
    background: linear-gradient(135deg, rgba(45,74,30,0.2) 0%, rgba(26,15,5,0.8) 100%);
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
  }
  .stat-card:hover { border-color: var(--ochre); }
  .stat-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0;
    width: 3px; height: 100%;
    background: var(--ochre);
  }
  .stat-tifinagh {
    font-size: 1.2rem;
    color: var(--ochre);
    opacity: 0.6;
    margin-bottom: 0.5rem;
    font-family: 'Cinzel Decorative', serif;
  }
  .stat-label {
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ochre);
    opacity: 0.8;
    margin-bottom: 0.5rem;
  }
  .stat-value {
    font-family: 'Space Mono', monospace;
    font-size: 1.6rem;
    color: var(--glow);
    font-weight: 700;
  }
  .stat-unit {
    font-size: 0.7rem;
    color: var(--ochre);
    opacity: 0.6;
    margin-top: 0.3rem;
  }
  .stat-trend { font-size: 0.75rem; margin-top: 0.5rem; }
  .trend-up { color: #5a9c3a; }
  .trend-dn { color: var(--terracotta); }

  /* world map placeholder */
  .world-section {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }
  .world-map-card {
    border: 1px solid rgba(200,168,75,0.25);
    background: rgba(26,58,92,0.15);
    position: relative;
    min-height: 340px;
    overflow: hidden;
  }
  .map-title {
    position: absolute;
    top: 1rem; left: 1rem;
    font-size: 0.65rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ochre);
    opacity: 0.8;
  }
  .world-events {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .event-item {
    border: 1px solid rgba(200,168,75,0.15);
    border-top: none;
    padding: 0.8rem 1rem;
    display: flex;
    gap: 0.8rem;
    align-items: flex-start;
    transition: background 0.2s;
    cursor: pointer;
  }
  .event-item:first-child { border-top: 1px solid rgba(200,168,75,0.15); }
  .event-item:hover { background: rgba(200,168,75,0.06); }
  .event-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-top: 4px;
    flex-shrink: 0;
  }
  .dot-green { background: #5a9c3a; box-shadow: 0 0 6px #5a9c3a; }
  .dot-yellow { background: var(--glow); box-shadow: 0 0 6px var(--glow); }
  .dot-red { background: var(--terracotta); box-shadow: 0 0 6px var(--terracotta); }
  .event-content .ev-title { font-size: 0.82rem; font-weight: 600; }
  .event-content .ev-sub { font-size: 0.68rem; color: var(--ochre); opacity: 0.7; margin-top: 2px; }
  .event-time { font-family: 'Space Mono', monospace; font-size: 0.65rem; color: var(--ochre); opacity: 0.5; margin-left: auto; white-space: nowrap; }

  /* ─── ARBRE DES FUTURS (tab 2) ─── */
  .tree-container {
    position: relative;
    min-height: 600px;
  }
  .tree-svg-wrap {
    width: 100%;
    overflow-x: auto;
  }
  .scenario-cards {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    margin-top: 2rem;
  }
  .scenario-card {
    border: 1px solid;
    padding: 1.5rem;
    cursor: pointer;
    transition: all 0.3s;
    position: relative;
    overflow: hidden;
  }
  .scenario-card.green { border-color: #5a9c3a; }
  .scenario-card.yellow { border-color: var(--ochre); }
  .scenario-card.red { border-color: var(--terracotta); }
  .scenario-card:hover { transform: translateY(-3px); }
  .scenario-card.green:hover { background: rgba(90,156,58,0.08); }
  .scenario-card.yellow:hover { background: rgba(200,168,75,0.08); }
  .scenario-card.red:hover { background: rgba(181,84,28,0.08); }
  .sc-percent {
    font-family: 'Space Mono', monospace;
    font-size: 3rem;
    font-weight: 700;
    line-height: 1;
  }
  .sc-percent.green { color: #5a9c3a; }
  .sc-percent.yellow { color: var(--ochre); }
  .sc-percent.red { color: var(--terracotta); }
  .sc-name { font-size: 1.1rem; font-weight: 700; letter-spacing: 0.1em; margin: 0.5rem 0; }
  .sc-desc { font-size: 0.78rem; opacity: 0.7; line-height: 1.5; }
  .sc-milestones { margin-top: 1rem; }
  .sc-milestone { font-size: 0.72rem; padding: 0.3rem 0; border-top: 1px solid rgba(200,168,75,0.1); display: flex; gap: 0.5rem; }
  .ms-year { font-family: 'Space Mono', monospace; color: var(--ochre); font-size: 0.68rem; opacity: 0.8; white-space: nowrap; }

  /* ─── JALONS TIMELINE (tab 3) ─── */
  .timeline-wrap {
    position: relative;
    padding-left: 3rem;
  }
  .timeline-line {
    position: absolute;
    left: 1rem;
    top: 0; bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--ochre), var(--terracotta));
  }
  .timeline-item {
    position: relative;
    margin-bottom: 1.5rem;
    cursor: pointer;
  }
  .timeline-dot {
    position: absolute;
    left: -2.55rem;
    top: 0.4rem;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--ochre);
    background: var(--deep);
    transition: all 0.3s;
  }
  .timeline-item:hover .timeline-dot { background: var(--ochre); transform: scale(1.3); }
  .timeline-item.past .timeline-dot { background: var(--ochre); border-color: var(--glow); }
  .timeline-item.now .timeline-dot { background: var(--glow); border-color: #fff; width: 16px; height: 16px; left: -2.7rem; box-shadow: 0 0 12px var(--glow); }
  .timeline-card {
    border: 1px solid rgba(200,168,75,0.2);
    padding: 1rem 1.2rem;
    background: rgba(26,15,5,0.5);
    transition: all 0.3s;
  }
  .timeline-item:hover .timeline-card { border-color: var(--ochre); background: rgba(200,168,75,0.06); }
  .timeline-item.now .timeline-card { border-color: var(--glow); background: rgba(240,192,96,0.06); }
  .tl-year { font-family: 'Space Mono', monospace; font-size: 1.1rem; color: var(--glow); font-weight: 700; }
  .tl-event { font-size: 0.95rem; font-weight: 600; margin: 0.2rem 0; }
  .tl-detail { font-size: 0.75rem; opacity: 0.65; line-height: 1.5; }
  .tl-badge { display: inline-block; font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 0.15rem 0.5rem; margin-bottom: 0.3rem; }
  .badge-env { background: rgba(90,156,58,0.2); color: #5a9c3a; border: 1px solid rgba(90,156,58,0.4); }
  .badge-tech { background: rgba(42,100,150,0.2); color: #64a6d4; border: 1px solid rgba(42,100,150,0.4); }
  .badge-social { background: rgba(200,168,75,0.2); color: var(--ochre); border: 1px solid rgba(200,168,75,0.4); }
  .badge-crisis { background: rgba(181,84,28,0.2); color: var(--terracotta); border: 1px solid rgba(181,84,28,0.4); }

  /* ─── DONNÉES EN TEMPS RÉEL (tab 4) ─── */
  .data-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }
  .data-card {
    border: 1px solid rgba(200,168,75,0.2);
    background: rgba(26,15,5,0.6);
    padding: 1.5rem;
  }
  .data-card-title {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ochre);
    margin-bottom: 1rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .data-live-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: #5a9c3a;
    animation: pulse 2s infinite;
  }
  @keyframes pulse {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(90,156,58,0.6); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(90,156,58,0); }
  }
  /* bar chart */
  .bar-chart { display: flex; flex-direction: column; gap: 0.6rem; }
  .bar-row { display: flex; align-items: center; gap: 0.7rem; }
  .bar-label { font-size: 0.72rem; width: 90px; flex-shrink: 0; opacity: 0.8; }
  .bar-track { flex: 1; background: rgba(200,168,75,0.1); height: 12px; position: relative; overflow: hidden; }
  .bar-fill { height: 100%; transition: width 1.5s ease; position: relative; }
  .bar-fill::after { content: ''; position: absolute; inset: 0; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.15)); }
  .bar-val { font-family: 'Space Mono', monospace; font-size: 0.68rem; color: var(--glow); width: 50px; text-align: right; flex-shrink: 0; }
  /* gauge */
  .gauge-row { display: flex; gap: 1.5rem; justify-content: space-around; }
  .gauge { text-align: center; }
  .gauge-svg { width: 100px; height: 100px; }
  .gauge-label { font-size: 0.65rem; letter-spacing: 0.1em; text-transform: uppercase; opacity: 0.7; margin-top: 0.3rem; }
  .gauge-val { font-family: 'Space Mono', monospace; font-size: 1rem; color: var(--glow); }

  /* ─── TIFINAGH DECORATION ─── */
  .tifinagh-border {
    border-image: none;
    position: relative;
  }
  .tifinagh-border::after {
    content: 'ⵣ ⵢ ⵏ ⵔ ⴻ ⵜ ⵙ ⴰ ⵎ ⵣ ⵢ ⵏ ⵔ ⴻ ⵜ ⵙ ⴰ ⵎ';
    position: absolute;
    bottom: -1px;
    left: 0;
    font-size: 0.55rem;
    letter-spacing: 0.5em;
    color: var(--ochre);
    opacity: 0.25;
    white-space: nowrap;
    overflow: hidden;
    width: 100%;
    font-family: 'Cinzel Decorative', serif;
  }

  /* ─── RAMIFICATIONS panel (tab 5) ─── */
  .branches-section {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .branch-group { }
  .branch-group-title {
    font-size: 0.7rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ochre);
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(200,168,75,0.2);
    margin-bottom: 1rem;
  }
  .branch-item {
    display: flex;
    gap: 1rem;
    padding: 0.8rem 0;
    border-bottom: 1px solid rgba(200,168,75,0.08);
    cursor: pointer;
    transition: all 0.2s;
  }
  .branch-item:hover { padding-left: 0.5rem; }
  .branch-icon {
    font-size: 1.4rem;
    width: 36px;
    text-align: center;
    flex-shrink: 0;
  }
  .branch-name { font-size: 0.9rem; font-weight: 600; }
  .branch-desc { font-size: 0.72rem; opacity: 0.6; margin-top: 2px; line-height: 1.4; }
  .branch-status {
    margin-left: auto;
    font-size: 0.6rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 0.2rem 0.6rem;
    border: 1px solid;
    height: fit-content;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .status-actif { border-color: #5a9c3a; color: #5a9c3a; }
  .status-critique { border-color: var(--terracotta); color: var(--terracotta); }
  .status-alerte { border-color: var(--ochre); color: var(--ochre); }

  /* ─── FOOTER ─── */
  footer {
    border-top: 1px solid rgba(200,168,75,0.2);
    padding: 1rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: rgba(26,15,5,0.9);
  }
  .footer-tifinagh {
    font-size: 0.85rem;
    color: var(--ochre);
    opacity: 0.4;
    letter-spacing: 0.4em;
    font-family: 'Cinzel Decorative', serif;
  }
  .footer-copy { font-size: 0.65rem; color: var(--ochre); opacity: 0.4; letter-spacing: 0.2em; }

  /* ─── MODAL ─── */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(26,15,5,0.9);
    z-index: 1000;
    align-items: center;
    justify-content: center;
  }
  .modal-overlay.open { display: flex; }
  .modal-box {
    border: 1px solid var(--ochre);
    background: var(--deep);
    max-width: 600px;
    width: 90%;
    padding: 2rem;
    position: relative;
    animation: fadeIn 0.3s ease;
  }
  .modal-close {
    position: absolute;
    top: 1rem; right: 1rem;
    background: none;
    border: 1px solid rgba(200,168,75,0.3);
    color: var(--ochre);
    width: 28px; height: 28px;
    cursor: pointer;
    font-size: 0.9rem;
    display: flex; align-items: center; justify-content: center;
  }
  .modal-close:hover { background: rgba(200,168,75,0.1); }

  /* responsive */
  @media (max-width: 1100px) {
    .obs-grid { grid-template-columns: repeat(2, 1fr); }
    .world-section { grid-template-columns: 1fr; }
    .data-grid { grid-template-columns: 1fr; }
    .scenario-cards { grid-template-columns: 1fr; }
    .branches-section { grid-template-columns: 1fr; }
  }
  @media (max-width: 700px) {
    nav button { padding: 0 0.5rem; font-size: 0.7rem; letter-spacing: 0.05em; }
    .obs-grid { grid-template-columns: 1fr 1fr; }
    .logo-tifinagh { font-size: 1.4rem; }
  }
</style>
</head>
<body>

<!-- ─── TIFINAGH BACKGROUND ─── -->
<div class="tifinagh-bg" aria-hidden="true">
<svg viewBox="0 0 800 600" preserveAspectRatio="xMidYMid slice">
  <!-- Tifinagh geometric symbols as SVG paths -->
  <defs>
    <pattern id="tif-pat" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
      <!-- ⵣ Yaz - central motif -->
      <line x1="40" y1="10" x2="40" y2="70" stroke="#c8a84b" stroke-width="1"/>
      <line x1="20" y1="30" x2="60" y2="30" stroke="#c8a84b" stroke-width="1"/>
      <line x1="20" y1="50" x2="60" y2="50" stroke="#c8a84b" stroke-width="1"/>
      <!-- corner marks -->
      <circle cx="20" cy="20" r="2" fill="#c8a84b"/>
      <circle cx="60" cy="20" r="2" fill="#c8a84b"/>
      <circle cx="20" cy="60" r="2" fill="#c8a84b"/>
      <circle cx="60" cy="60" r="2" fill="#c8a84b"/>
      <!-- diamond -->
      <polygon points="40,12 52,25 40,38 28,25" stroke="#c8a84b" stroke-width="0.8" fill="none"/>
    </pattern>
    <pattern id="tif-border" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
      <line x1="20" y1="5" x2="20" y2="35" stroke="#c8a84b" stroke-width="0.8"/>
      <line x1="5" y1="20" x2="35" y2="20" stroke="#c8a84b" stroke-width="0.8"/>
      <rect x="10" y="10" width="20" height="20" stroke="#c8a84b" stroke-width="0.5" fill="none" transform="rotate(45 20 20)"/>
    </pattern>
  </defs>
